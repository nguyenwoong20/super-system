# ============================================================
# .env.example — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the real .env file to Git!
# ============================================================

# ── Node Environment ──────────────────────────────────────
NODE_ENV=development

# ── Auth Service ──────────────────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_DATABASE_URL=postgresql://auth_user:auth_pass@localhost:5432/auth_db
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Ticket Service ────────────────────────────────────────
TICKET_SERVICE_PORT=3002
TICKET_DATABASE_URL=postgresql://tickets_user:tickets_pass@localhost:5433/tickets_db

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── AWS (for deployment) ──────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
ECS_CLUSTER=super-system-cluster
EFS_FILESYSTEM_ID=fs-xxxxxxxxxxxxxxxxx

# ── Cloudflare Tunnel ─────────────────────────────────────
CLOUDFLARE_TUNNEL_UUID=your-tunnel-uuid-here
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
