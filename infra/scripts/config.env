# ============================================================
# Deployment Config
# File: infra/scripts/config.env
#
# ⚠️  EDIT THIS FILE BEFORE RUNNING ANY SCRIPTS
# Điền thông tin của bạn vào đây
# ============================================================

# ── AWS Settings ───────────────────────────────────────────
export AWS_REGION="ap-southeast-1"         # Singapore (gần VN nhất)
export AWS_DEFAULT_REGION="ap-southeast-1"

# ── Project Settings ───────────────────────────────────────
export PROJECT_NAME="super-system"
export ENVIRONMENT="production"

# ── Alert Email (optional) ─────────────────────────────────
# Nhận email khi hệ thống có vấn đề (CPU cao, 5xx errors...)
# Để trống nếu không cần
export ALERT_EMAIL=""

# ── AWS Credentials ────────────────────────────────────────
# Cách 1: Đã cấu hình sẵn qua `aws configure` → để trống 2 dòng dưới
# Cách 2: Điền trực tiếp (không khuyến khích commit lên Git)
# export AWS_ACCESS_KEY_ID="YOUR_ACCESS_KEY_HERE"
# export AWS_SECRET_ACCESS_KEY="YOUR_SECRET_KEY_HERE"

# Ensure AWS CLI is in PATH (especially for Git Bash on Windows)
export PATH=$PATH:"/c/Program Files/Amazon/AWSCLIV2"

