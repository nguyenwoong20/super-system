{
  "family": "super-system-postgres-auth",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::080705554161:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::080705554161:role/super-system-task-role",
  "volumes": [{
    "name": "postgres-auth-data",
    "efsVolumeConfiguration": {
      "fileSystemId": "fs-00c54f259f16e5108",
      "transitEncryption": "ENABLED",
      "authorizationConfig": { "accessPointId": "fsap-0ba67f8a86572ef91", "iam": "ENABLED" }
    }
  }],
  "containerDefinitions": [{
    "name": "postgres-auth",
    "image": "080705554161.dkr.ecr.ap-southeast-1.amazonaws.com/super-system/postgres:16-alpine",
    "user": "999",
    "essential": true,
    "portMappings": [{"containerPort": 5432, "protocol": "tcp"}],
    "environment": [
      {"name": "POSTGRES_DB", "value": "auth_db"},
      {"name": "POSTGRES_USER", "value": "auth_user"},
      {"name": "PGDATA", "value": "/var/lib/postgresql/data/pgdata"}
    ],
    "secrets": [{"name": "POSTGRES_PASSWORD", "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:080705554161:secret:super-system/auth/db-password-kow5Ra"}],
    "mountPoints": [{"sourceVolume": "postgres-auth-data", "containerPath": "/var/lib/postgresql/data"}],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/super-system/postgres",
        "awslogs-region": "ap-southeast-1",
        "awslogs-stream-prefix": "auth-db"
      }
    },
    "healthCheck": {
      "command": ["CMD-SHELL", "pg_isready -U auth_user -d auth_db"],
      "interval": 30, "timeout": 5, "retries": 5, "startPeriod": 30
    }
  }]
}
