{
  "family": "super-system-nginx-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::080705554161:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::080705554161:role/super-system-task-role",
  "containerDefinitions": [{
    "name": "nginx-gateway",
    "image": "080705554161.dkr.ecr.ap-southeast-1.amazonaws.com/super-system/nginx-gateway:latest",
    "essential": true,
    "portMappings": [{"containerPort": 80, "protocol": "tcp"}],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/super-system/nginx-gateway",
        "awslogs-region": "ap-southeast-1",
        "awslogs-stream-prefix": "ecs"
      }
    },
    "healthCheck": {
      "command": ["CMD-SHELL", "curl -f http://localhost:80/health || exit 1"],
      "interval": 15, "timeout": 5, "retries": 3, "startPeriod": 30
    }
  }]
}
